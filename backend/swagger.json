{
  "openapi": "3.0.0",
  "info": {
    "title": "UrbanPulse API",
    "version": "1.0.0",
    "description": "API documentation for the FIICode UrbanPulse backend."
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new neighbor",
        "description": "Creates a new user account and returns a session token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "displayName"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "neighbor@iasi.ro" },
                  "displayName": { "type": "string", "example": "Alex Slanina" },
                  "password": { "type": "string", "minLength": 8, "example": "securePassword123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully registered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string", "description": "JWT Session Token" },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid" },
                        "role": { "type": "string", "example": "user" }
                      }
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Email already exists",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "An account with this email already exists" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Already authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {"type": "string", "example": "You are already authenticated. Please log out first."}
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request or Invalid body",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Invalid body" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Something is wrong with the server",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {"type": "string", "example": "Internal error"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login an existing neighbor",
        "description": "Authenticates a user and returns a session token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "neighbor@iasi.ro" },
                  "password": { "type": "string", "example": "securePassword123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string", "description": "JWT Session Token" },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid" },
                        "role": { "type": "string", "example": "user" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Invalid credentials" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request or Invalid body",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Invalid body" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Something is wrong with the server",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {"type": "string", "example": "Internal error"}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
