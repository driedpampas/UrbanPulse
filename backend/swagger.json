{
  "openapi": "3.0.0",
  "info": {
    "title": "UrbanPulse API",
    "version": "1.1.0",
    "description": "API documentation for the FIICode UrbanPulse backend."
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new neighbor",
        "description": "Creates a new user account and returns a session token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "displayName"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "neighbor@iasi.ro" },
                  "displayName": { "type": "string", "example": "Alex Slanina" },
                  "password": { "type": "string", "minLength": 8, "example": "securePassword123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully registered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string", "description": "JWT Session Token" },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid" },
                        "role": { "type": "string", "example": "user" }
                      }
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Email already exists"
          },
          "403": {
            "description": "Already authenticated"
          },
          "400": {
            "description": "Bad request or Invalid body"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login an existing neighbor",
        "description": "Authenticates a user and returns a session token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "neighbor@iasi.ro" },
                  "password": { "type": "string", "example": "securePassword123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string", "description": "JWT Session Token" },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid" },
                        "role": { "type": "string", "example": "user" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          },
          "400": {
            "description": "Bad request or Invalid body"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/api/user": {
      "patch": {
        "summary": "Update existing user",
        "description": "Updates the existing user, identified with the session token, with the provided parameters.",
        "security": [
          { "bearerAuth": [] }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "displayName": { "type": "string", "example": "Alex Slatina" },
                  "radius": {"type": "integer", "description": "The radius in meters", "example": 800},
                  "location": {
                    "type": "object",
                    "properties": {
                      "lat": {"type": "number", "example": 10.67},
                      "lng": {"type": "number", "example": 20.69}
                    }
                  },
                  "quietHours": {
                    "type": "object",
                    "properties": {
                      "start": {"type": "string", "example": "22:00"},
                      "end": {"type": "string", "example": "06:00"}
                    },
                    "nullable": true
                  },
                  "quietDays": {
                    "type": "array",
                    "example": [0, 6],
                    "items": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 6
                    },
                    "maximum": 7,
                    "nullable": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile successfully updated or nothing to update"
          },
          "400": {
            "description": "Bad request or Invalid body"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    }
  }
}
